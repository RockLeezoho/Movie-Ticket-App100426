<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp">

        <View
            android:id="@+id/payment_history_accent"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@color/movie_secondary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/payment_history_movie_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="Tên phim"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/payment_history_accent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/payment_history_theater"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="4dp"
            android:text="Rạp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/payment_history_accent"
            app:layout_constraintTop_toBottomOf="@id/payment_history_movie_title" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/payment_history_accent"
            app:layout_constraintTop_toBottomOf="@id/payment_history_theater">

            <TextView
                android:id="@+id/payment_history_seat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_tag_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Ghế: A1"
                android:textColor="@color/movie_on_surface"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/payment_history_method"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="MoMo"
                android:textColor="@color/movie_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/payment_history_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_tag_chip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="HOÀN THÀNH"
            android:textColor="@color/movie_rating"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/payment_history_accent"
            app:layout_constraintTop_toBottomOf="@id/payment_history_method" />

        <TextView
            android:id="@+id/payment_history_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_tag_chip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="$0.00"
            android:textColor="@color/movie_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/payment_history_theater" />

        <TextView
            android:id="@+id/payment_history_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="12dp"
            android:text="Ngày giờ"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/payment_history_amount"
            app:layout_constraintStart_toEndOf="@id/payment_history_accent"
            app:layout_constraintTop_toBottomOf="@id/payment_history_status" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>