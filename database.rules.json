{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['id', 'email', 'fullName'])"
      }
    },
    "movies": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "theaters": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "showtimes": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["movieId"]
    },
    "seedVersion": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "tickets": {
      ".indexOn": ["userId"],
      "$ticketId": {
        ".read": "auth != null && data.child('userId').val() === auth.uid",
        ".write": "auth != null && newData.child('userId').val() === auth.uid",
        ".validate": "newData.hasChildren(['id', 'userId', 'showtimeId', 'movieTitle', 'theaterName', 'time', 'seatNumber', 'price', 'showtimeMillis'])"
      }
    },
    "payments": {
      ".indexOn": ["userId"],
      "$paymentId": {
        ".read": "auth != null && data.child('userId').val() === auth.uid",
        ".write": "auth != null && newData.child('userId').val() === auth.uid",
        ".validate": "newData.hasChildren(['id', 'userId', 'ticketId', 'showtimeId', 'movieTitle', 'theaterName', 'seatNumber', 'paymentMethod', 'status', 'amount', 'createdAtMillis'])"
      }
    }
  }
}



